<script type="module">
const FirebaseCDN = {
  app: 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js',
  firestore: 'https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js'
};

const PRODUCTS = window.PRODUCTS;
const DEMO_KEY = 'picatti_demo_orders_v1';
const FIREBASE_KEY = 'picatti_firebase_config_v1';

let state = { mode: 'demo', currentCart: [], orders: [], db: null, unsubscribe: null };

function money(n) { return '$' + Number(n || 0).toFixed(2); }
function escapeHtml(s) { return String(s ?? '').replace(/[&<>"']/g, m => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[m]); }
function switchTab(id, btn) {
  for (const el of document.querySelectorAll('.tabbtn')) el.classList.remove('active');
  if (btn) btn.classList.add('active');
  for (const el of ['employeeTab','dashboardTab','setupTab']) {
    document.getElementById(el).classList.toggle('hidden', el !== id);
  }
}
window.switchTab = switchTab;

function savedDemoOrders() { try { return JSON.parse(localStorage.getItem(DEMO_KEY) || '[]'); } catch { return []; } }
function saveDemoOrders() { localStorage.setItem(DEMO_KEY, JSON.stringify(state.orders)); }
function getSavedFirebaseConfig() {
  try { const raw = localStorage.getItem(FIREBASE_KEY); return raw ? JSON.parse(raw) : null; } catch { return null; }
}
function setModeBadge() {
  const el = document.getElementById('modeBadge');
  if (state.mode === 'firebase') {
    el.className = 'pill';
    el.textContent = 'Shared Firebase mode';
  } else {
    el.className = 'pill mode-demo';
    el.textContent = 'Demo mode: single device only';
  }
}
function populateCategoryFilter() {
  const categories = [...new Set(PRODUCTS.map(p => p.category))].sort();
  const sel = document.getElementById('categoryFilter');
  sel.innerHTML = '<option value="">All categories</option>' + categories.map(c => `<option>${escapeHtml(c)}</option>`).join('');
}
function renderProducts() {
  const grid = document.getElementById('productGrid');
  const search = document.getElementById('searchBox').value.trim().toLowerCase();
  const audience = document.getElementById('audienceFilter').value;
  const category = document.getElementById('categoryFilter').value;
  let items = PRODUCTS.filter(p => {
    const hitSearch = !search || (p.name + ' ' + p.sku + ' ' + p.category + ' ' + p.audience).toLowerCase().includes(search);
    const hitAudience = !audience || p.audience === audience;
    const hitCategory = !category || p.category === category;
    return hitSearch && hitAudience && hitCategory;
  });
  grid.innerHTML = '';
  if (!items.length) { grid.innerHTML = '<div class="notice warn">No garments matched your filters.</div>'; return; }
  items.forEach(p => {
    const first = p.colors[0];
    const card = document.createElement('div');
    card.className = 'product';
    card.innerHTML = `
      <img id="img_${p.id}" src="${first.image}" alt="${escapeHtml(p.name)}">
      <div class="product-body">
        <div class="sku">${escapeHtml(p.sku)} • ${escapeHtml(p.category)} • ${escapeHtml(p.audience)}</div>
        <h3>${escapeHtml(p.name)}</h3>
        <div class="tiny muted">Employee price: $0.00</div>
        <div class="price">Vendor cost: ${money(p.cost)}</div>
        <label>Color</label>
        <select id="color_${p.id}" onchange="window.changeProductImage('${p.id}')">
          ${p.colors.map((c, i) => `<option value="${i}">${escapeHtml(c.name)}</option>`).join('')}
        </select>
        <label style="margin-top:8px;">Size</label>
        <select id="size_${p.id}">
          ${p.sizes.map(s => `<option>${escapeHtml(s)}</option>`).join('')}
        </select>
        <label style="margin-top:8px;">Quantity</label>
        <select id="qty_${p.id}">
          <option>1</option><option>2</option><option>3</option><option>4</option><option>5</option>
        </select>
        <button class="btn" style="margin-top:10px;" onclick="window.addToCart('${p.id}')">Add to Cart</button>
      </div>
    `;
    grid.appendChild(card);
  });
}
window.changeProductImage = function(productId) {
  const p = PRODUCTS.find(x => x.id === productId);
  const idx = Number(document.getElementById('color_' + productId).value || 0);
  document.getElementById('img_' + productId).src = p.colors[idx].image;
}
function getCartCount() { return state.currentCart.reduce((a, b) => a + Number(b.qty), 0); }
window.addToCart = function(productId) {
  const employeeName = document.getElementById('employeeName').value.trim();
  const dept = document.getElementById('employeeDept').value.trim();
  if (!employeeName) { alert('Please enter employee name first.'); return; }
  const p = PRODUCTS.find(x => x.id === productId);
  const qty = Number(document.getElementById('qty_' + productId).value || 1);
  if (getCartCount() + qty > 7) { alert('This employee can only select 7 total items.'); return; }
  const colorIdx = Number(document.getElementById('color_' + productId).value || 0);
  const color = p.colors[colorIdx].name;
  const size = document.getElementById('size_' + productId).value;
  state.currentCart.push({ id: crypto.randomUUID(), productId: p.id, sku: p.sku, item: p.name, category: p.category, audience: p.audience, employee: employeeName, dept, color, size, qty, cost: p.cost });
  renderCart();
}
window.clearCart = function() { state.currentCart = []; renderCart(); }
window.submitCart = async function() {
  const employeeName = document.getElementById('employeeName').value.trim();
  const dept = document.getElementById('employeeDept').value.trim();
  if (!employeeName) { alert('Enter employee name.'); return; }
  if (!state.currentCart.length) { alert('Cart is empty.'); return; }
  const count = getCartCount();
  if (count !== 7) { alert('Each employee must submit exactly 7 items.'); return; }
  const order = { employee: employeeName, dept, itemCount: count, totalCost: state.currentCart.reduce((a, b) => a + Number(b.qty) * Number(b.cost), 0), items: state.currentCart, submittedAt: new Date().toISOString() };
  try {
    if (state.mode === 'firebase' && state.db) {
      const { collection, addDoc } = await import(FirebaseCDN.firestore);
      await addDoc(collection(state.db, 'orders'), order);
    } else {
      state.orders.push({ id: crypto.randomUUID(), ...order });
      saveDemoOrders();
      updateDashboard();
    }
    state.currentCart = [];
    renderCart();
    alert('Order submitted.');
    switchTab('dashboardTab', document.querySelector('[data-tab="dashboardTab"]'));
  } catch (e) {
    console.error(e);
    alert('Could not submit the order.');
  }
}
function renderCart() {
  const wrap = document.getElementById('cartLines');
  const count = getCartCount();
  const total = state.currentCart.reduce((a, b) => a + Number(b.qty) * Number(b.cost), 0);
  document.getElementById('cartPieces').textContent = count;
  document.getElementById('piecesLeft').textContent = 7 - count;
  document.getElementById('cartCost').textContent = money(total);
  const notice = document.getElementById('shoppingNotice');
  if (count === 7) { notice.className = 'notice good'; notice.textContent = 'This employee has exactly 7 items selected and can submit.'; }
  else { notice.className = 'notice warn'; notice.textContent = `This employee still needs ${7 - count} item(s) before submitting.`; }
  wrap.innerHTML = '';
  if (!state.currentCart.length) { wrap.innerHTML = '<div class="notice warn">Cart is empty.</div>'; return; }
  state.currentCart.forEach(line => {
    const div = document.createElement('div');
    div.className = 'cart-line';
    div.innerHTML = `<strong>${escapeHtml(line.item)} <span class="right">${money(line.qty * line.cost)}</span></strong><div class="tiny muted">${escapeHtml(line.color)} • Size ${escapeHtml(line.size)} • Qty ${line.qty}</div><button class="btn-danger btn-inline" style="margin-top:8px;" onclick="window.removeCartLine('${line.id}')">Remove</button>`;
    wrap.appendChild(div);
  });
}
window.removeCartLine = function(id) { state.currentCart = state.currentCart.filter(x => x.id !== id); renderCart(); }
function allOrderRows() {
  const rows = [];
  state.orders.forEach(order => { (order.items || []).forEach(item => rows.push(item)); });
  return rows;
}
function groupedVendorTotals() {
  const grouped = {};
  allOrderRows().forEach(r => {
    const key = [r.sku, r.item, r.color, r.size, r.cost].join('||');
    if (!grouped[key]) grouped[key] = { sku:r.sku, item:r.item, color:r.color, size:r.size, cost:r.cost, qty:0 };
    grouped[key].qty += Number(r.qty);
  });
  return Object.values(grouped).sort((a,b)=>(a.item+a.color+a.size).localeCompare(b.item+b.color+b.size));
}
function updateDashboard() {
  const orders = state.orders;
  const rows = allOrderRows();
  const employees = [...new Set(orders.map(o => o.employee))];
  document.getElementById('sumEmployees').textContent = employees.length;
  document.getElementById('sumOrders').textContent = orders.length;
  document.getElementById('sumPieces').textContent = rows.reduce((a,b)=>a+Number(b.qty),0);
  document.getElementById('sumCost').textContent = money(rows.reduce((a,b)=>a+Number(b.qty)*Number(b.cost),0));
  const body = document.querySelector('#vendorTotalsTable tbody');
  body.innerHTML = '';
  groupedVendorTotals().forEach(r => {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td>${escapeHtml(r.sku)}</td><td>${escapeHtml(r.item)}</td><td>${escapeHtml(r.color)}</td><td>${escapeHtml(r.size)}</td><td>${r.qty}</td><td>${money(r.qty * r.cost)}</td>`;
    body.appendChild(tr);
  });
  const list = document.getElementById('ordersList');
  list.innerHTML = '';
  if (!orders.length) { list.innerHTML = '<div class="notice warn">No employee orders yet.</div>'; return; }
  orders.slice().sort((a,b)=>(b.submittedAt||'').localeCompare(a.submittedAt||'')).forEach(order => {
    const div = document.createElement('div');
    div.className = 'order-card';
    div.innerHTML = `<div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;"><div><strong>${escapeHtml(order.employee)}</strong> • ${escapeHtml(order.dept || '-')}</div><div><strong>${order.itemCount}</strong> items • <strong>${money(order.totalCost)}</strong></div></div><div class="tiny muted" style="margin-top:6px;">${new Date(order.submittedAt).toLocaleString()}</div><div class="tiny" style="margin-top:8px;">${(order.items||[]).map(i => `${escapeHtml(i.sku)} ${escapeHtml(i.item)} / ${escapeHtml(i.color)} / ${escapeHtml(i.size)} x${i.qty}`).join('<br>')}</div>`;
    list.appendChild(div);
  });
}
function csv(rows) {
  return rows.map(r => r.map(cell => {
    const s = String(cell ?? '');
    return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
  }).join(',')).join('\n');
}
function download(name, content, mime='text/csv;charset=utf-8;') {
  const blob = new Blob([content], { type: mime });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = name;
  a.click();
}
window.exportVendorTotals = function() {
  const rows = [['SKU','Item','Color','Size','Qty','Unit Cost','Extended Cost']];
  groupedVendorTotals().forEach(r => rows.push([r.sku, r.item, r.color, r.size, r.qty, r.cost, (r.qty*r.cost).toFixed(2)]));
  download('vendor_totals.csv', csv(rows));
}
window.exportEmployeeOrders = function() {
  const rows = [['Employee','Department','SKU','Item','Color','Size','Qty','Unit Cost','Extended Cost','Submitted At']];
  state.orders.forEach(order => (order.items||[]).forEach(i => rows.push([order.employee, order.dept || '', i.sku, i.item, i.color, i.size, i.qty, i.cost, (i.qty*i.cost).toFixed(2), order.submittedAt])));
  download('employee_orders.csv', csv(rows));
}
function employeeSheetHtml(order) {
  return `<div style="page-break-after:always;padding:18px;font-family:Arial,Helvetica,sans-serif;"><div style="display:flex;justify-content:space-between;gap:10px;align-items:flex-start;border-bottom:2px solid #111;padding-bottom:10px;margin-bottom:14px;"><div><div style="font-size:24px;font-weight:800;">Picatti Brothers Order Sheet</div><div style="margin-top:6px;font-size:18px;font-weight:700;">${escapeHtml(order.employee)}</div><div style="color:#555;">Department: ${escapeHtml(order.dept || '-')}</div></div><div style="text-align:right;"><div><strong>Items:</strong> ${order.itemCount}</div><div><strong>Vendor Cost:</strong> ${money(order.totalCost)}</div></div></div><table style="width:100%;border-collapse:collapse;"><thead><tr><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">SKU</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Item</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Color</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Size</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Qty</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Pulled</th></tr></thead><tbody>${(order.items||[]).map(i => `<tr><td style="padding:8px;border-bottom:1px solid #ddd;">${escapeHtml(i.sku)}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${escapeHtml(i.item)}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${escapeHtml(i.color)}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${escapeHtml(i.size)}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${i.qty}</td><td style="padding:8px;border-bottom:1px solid #ddd;">____</td></tr>`).join('')}</tbody></table></div>`;
}
window.printAllEmployeeSheets = function() {
  const html = state.orders.length ? state.orders.map(employeeSheetHtml).join('') : '<div style="padding:20px;font-family:Arial;">No orders yet.</div>';
  const w = window.open('', '_blank');
  w.document.write(`<html><head><title>Employee Sheets</title></head><body>${html}</body></html>`);
  w.document.close(); w.focus(); w.print();
}
window.printPullSummary = function() {
  const grouped = {};
  allOrderRows().forEach(r => {
    const key = [r.sku, r.item, r.color, r.size].join('||');
    if (!grouped[key]) grouped[key] = { sku:r.sku, item:r.item, color:r.color, size:r.size, qty:0, employees:{} };
    grouped[key].qty += Number(r.qty);
    grouped[key].employees[r.employee] = (grouped[key].employees[r.employee] || 0) + Number(r.qty);
  });
  const rows = Object.values(grouped).sort((a,b)=>(a.item+a.color+a.size).localeCompare(b.item+b.color+b.size));
  const html = rows.length ? `<div style="padding:18px;font-family:Arial,Helvetica,sans-serif;"><div style="font-size:24px;font-weight:800;margin-bottom:12px;">Picatti Brothers Pull Summary</div><div style="margin-bottom:14px;color:#555;">Use this when bulk inventory arrives and you need to stage items by SKU, color, and size.</div><table style="width:100%;border-collapse:collapse;"><thead><tr><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">SKU</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Item</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Color</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Size</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Total Qty</th><th style="text-align:left;border-bottom:1px solid #999;padding:8px;">Employees</th></tr></thead><tbody>${rows.map(r => `<tr><td style="padding:8px;border-bottom:1px solid #ddd;">${escapeHtml(r.sku)}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${escapeHtml(r.item)}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${escapeHtml(r.color)}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${escapeHtml(r.size)}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${r.qty}</td><td style="padding:8px;border-bottom:1px solid #ddd;">${Object.entries(r.employees).map(([n,q]) => `${escapeHtml(n)} (${q})`).join(', ')}</td></tr>`).join('')}</tbody></table></div>` : '<div style="padding:20px;font-family:Arial;">No orders yet.</div>';
  const w = window.open('', '_blank');
  w.document.write(`<html><head><title>Pull Summary</title></head><body>${html}</body></html>`);
  w.document.close(); w.focus(); w.print();
}
window.clearAllOrders = async function() {
  if (!confirm('Clear all orders?')) return;
  try {
    if (state.mode === 'firebase' && state.db) {
      const { collection, getDocs, deleteDoc, doc } = await import(FirebaseCDN.firestore);
      const snap = await getDocs(collection(state.db, 'orders'));
      for (const d of snap.docs) { await deleteDoc(doc(state.db, 'orders', d.id)); }
    } else {
      state.orders = [];
      saveDemoOrders();
      updateDashboard();
    }
  } catch (e) {
    console.error(e);
    alert('Could not clear orders.');
  }
}
window.saveFirebaseConfig = async function() {
  const raw = document.getElementById('firebaseConfigInput').value.trim();
  if (!raw) {
    localStorage.removeItem(FIREBASE_KEY);
    document.getElementById('setupStatus').className = 'notice warn';
    document.getElementById('setupStatus').textContent = 'Firebase config cleared. The app is now in single-device demo mode.';
    await initDataMode();
    return;
  }
  try {
    const cfg = JSON.parse(raw);
    localStorage.setItem(FIREBASE_KEY, JSON.stringify(cfg));
    document.getElementById('setupStatus').className = 'notice good';
    document.getElementById('setupStatus').textContent = 'Firebase config saved. Reloading shared mode now.';
    await initDataMode();
  } catch {
    alert('Firebase config is not valid JSON.');
  }
}
window.loadSavedFirebaseConfig = function() {
  const cfg = getSavedFirebaseConfig();
  document.getElementById('firebaseConfigInput').value = cfg ? JSON.stringify(cfg, null, 2) : '';
}
async function initFirebase(cfg) {
  const firebaseAppMod = await import(FirebaseCDN.app);
  const firestoreMod = await import(FirebaseCDN.firestore);
  const app = firebaseAppMod.initializeApp(cfg);
  const db = firestoreMod.getFirestore(app);
  if (state.unsubscribe) state.unsubscribe();
  state.db = db;
  state.mode = 'firebase';
  state.unsubscribe = firestoreMod.onSnapshot(firestoreMod.collection(db, 'orders'), snap => {
    state.orders = snap.docs.map(d => ({ id:d.id, ...d.data() }));
    updateDashboard();
  });
}
async function initDataMode() {
  const cfg = getSavedFirebaseConfig();
  if (cfg && cfg.projectId && cfg.apiKey && cfg.appId) {
    try {
      await initFirebase(cfg);
      document.getElementById('setupStatus').className = 'notice good';
      document.getElementById('setupStatus').textContent = 'Firebase connected. Employee phones will share one employer dashboard.';
    } catch (e) {
      console.error(e);
      state.mode = 'demo';
      state.orders = savedDemoOrders();
      document.getElementById('setupStatus').className = 'notice warn';
      document.getElementById('setupStatus').textContent = 'Firebase could not connect. The app is in demo mode until the config is corrected.';
      updateDashboard();
    }
  } else {
    state.mode = 'demo';
    state.orders = savedDemoOrders();
    document.getElementById('setupStatus').className = 'notice warn';
    document.getElementById('setupStatus').textContent = 'No Firebase config saved yet. The app is currently in single-device demo mode.';
    updateDashboard();
  }
  setModeBadge();
  window.loadSavedFirebaseConfig();
}
function init() {
  populateCategoryFilter();
  renderProducts();
  renderCart();
  updateDashboard();
  setModeBadge();
  initDataMode();
}
init();
</script>
